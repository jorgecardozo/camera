# Protect the app with a password (HTTP Basic Auth).
# Leave empty or unset for no authentication (local dev default).
APP_PASSWORD=

# ── Retention ────────────────────────────────────────────────────────────────
# Delete recordings older than this many hours (0 = disable age-based deletion).
# For a 1-week vacation: 168   (7 days)
# For a 2-week vacation: 336  (14 days)
MAX_RECORDING_AGE_HOURS=72

# Delete oldest recordings when total size exceeds this limit in GB.
# Estimate: ~1.5 GB/hour per camera at 1080p (RTSP copy, no re-encode).
# 1 cam × 1 week  ≈  250 GB
# 2 cams × 1 week ≈  500 GB
# 4 cams × 1 week ≈ 1000 GB
# 4 cams × 2 weeks≈ 2000 GB
MAX_RECORDINGS_GB=10

# ── Segmentation ─────────────────────────────────────────────────────────────
# Split continuous recordings into segments of this length in minutes.
# Shorter segments = easier to browse but more files.
RECORDING_SEGMENT_MINUTES=30
